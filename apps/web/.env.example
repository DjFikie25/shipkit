# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Neon PostgreSQL (REQUIRED) ────────────────────────────────────────────────
# neon.tech → your project → Connection string (pooled)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Google OAuth (OPTIONAL) ───────────────────────────────────────────────────
# Leave blank to disable Google sign-in entirely.
# console.cloud.google.com → Credentials → Create OAuth 2.0 client
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend — email for password reset (OPTIONAL) ──────────────────────────────
# Leave blank to use console.log fallback (dev-friendly).
# resend.com → API Keys → Create API key
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── AI Providers (configure at least one) ─────────────────────────────────────
# Groq (fast, free tier): console.groq.com
GROQ_API_KEY=
# OpenAI: platform.openai.com
OPENAI_API_KEY=
# Anthropic: console.anthropic.com
ANTHROPIC_API_KEY=
# Google AI: aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY=

# Active AI provider: groq | openai | anthropic | google (default: groq)
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
AI_MODEL_FAST=llama-3.1-8b-instant
