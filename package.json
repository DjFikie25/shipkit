{
  "name": "shipkit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@template/web",
    "dev:mobile": "turbo dev --filter=@template/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@template/web",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e --filter=@template/web",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
